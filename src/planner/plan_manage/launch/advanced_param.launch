<launch>
  <!-- ====== Args（与 ROS2 版保持一致的默认值） ====== -->
  <arg name="drone_id"    default="0"/>
  <!-- ROS1 不支持表达式拼接，节点名直接给默认值；如需按 drone_id 拼接，调用处传入即可 -->
  <arg name="name_of_ego_planner_node" default="ego_planner_0"/>

  <!-- 话题（父 launch 可覆盖） -->
  <arg name="odometry_topic"    default="/vins/odometry"/>
  <arg name="camera_pose_topic" default="/ego/camera_pose_ps"/>
  <!-- 你当前链路默认用点云，深度占位为 /unused -->
  <arg name="depth_topic"       default="/unused"/>
  <arg name="cloud_topic"       default="/ego/points"/>

  <!-- 地图尺寸 -->
  <arg name="map_size_x_" default="50.0"/>
  <arg name="map_size_y_" default="25.0"/>
  <arg name="map_size_z_" default="2.0"/>

  <!-- 相机内参（640×480） -->
  <arg name="cx" default="335.18186"/>
  <arg name="cy" default="217.7217"/>
  <arg name="fx" default="391.50625"/>
  <arg name="fy" default="395.18355"/>

  <!-- 规划 / 飞行 -->
  <arg name="flight_type"        default="2"/>
  <arg name="planning_horizon"   default="7.5"/>
  <arg name="use_distinctive_trajs" default="true"/>
  <arg name="max_vel"            default="2.0"/>
  <arg name="max_acc"            default="6.0"/>

  <!-- 动态障碍/多目标预测数量 -->
  <arg name="obj_num_set" default="10"/>

  <!-- 航点（与 ROS2 版一致） -->
  <arg name="point_num" default="4"/>

  <arg name="point0_x" default="15.0"/>
  <arg name="point0_y" default="0.0"/>
  <arg name="point0_z" default="1.0"/>

  <arg name="point1_x" default="-15.0"/>
  <arg name="point1_y" default="0.0"/>
  <arg name="point1_z" default="1.0"/>

  <arg name="point2_x" default="15.0"/>
  <arg name="point2_y" default="0.0"/>
  <arg name="point2_z" default="1.0"/>

  <arg name="point3_x" default="-15.0"/>
  <arg name="point3_y" default="0.0"/>
  <arg name="point3_z" default="1.0"/>

  <arg name="point4_x" default="15.0"/>
  <arg name="point4_y" default="0.0"/>
  <arg name="point4_z" default="1.0"/>

  <!-- ====== ego_planner 节点 ====== -->
  <node pkg="ego_planner" type="ego_planner_node" name="$(arg name_of_ego_planner_node)" output="screen">
    <!-- remap：严格按 ROS2 版映射 -->
    <remap from="odom_world" to="$(arg odometry_topic)"/>

    <!-- 形成 /drone_<id>_planning/bspline -->
    <remap from="planning/bspline" to="/drone_$(arg drone_id)_planning/bspline"/>

    <remap from="planning/data_display" to="planning/data_display"/>
    <remap from="planning/broadcast_bspline_from_planner" to="/broadcast_bspline"/>
    <remap from="planning/broadcast_bspline_to_planner"   to="/broadcast_bspline"/>

    <remap from="grid_map/odom"  to="$(arg odometry_topic)"/>
    <remap from="grid_map/pose"  to="$(arg camera_pose_topic)"/>
    <remap from="grid_map/depth" to="$(arg depth_topic)"/>
    <remap from="grid_map/cloud" to="$(arg cloud_topic)"/>

    <remap from="grid_map/occupancy_inflate" to="grid_map/occupancy_inflate"/>
    <remap from="optimal_list" to="optimal_list"/>

    <!-- parameters：名称保持不变（使用“命名空间式”key） -->
    <!-- FSM -->
    <param name="fsm/flight_type"              value="$(arg flight_type)"/>
    <param name="fsm/thresh_replan_time"       value="1.0"/>
    <param name="fsm/thresh_no_replan_meter"   value="1.0"/>
    <param name="fsm/planning_horizon"         value="$(arg planning_horizon)"/>
    <param name="fsm/planning_horizen_time"    value="3.0"/>
    <param name="fsm/emergency_time"           value="1.0"/>
    <param name="fsm/realworld_experiment"     value="false"/>
    <param name="fsm/fail_safe"                value="true"/>

    <param name="fsm/waypoint_num" value="$(arg point_num)"/>
    <param name="fsm/waypoint0_x" value="$(arg point0_x)"/>
    <param name="fsm/waypoint0_y" value="$(arg point0_y)"/>
    <param name="fsm/waypoint0_z" value="$(arg point0_z)"/>
    <param name="fsm/waypoint1_x" value="$(arg point1_x)"/>
    <param name="fsm/waypoint1_y" value="$(arg point1_y)"/>
    <param name="fsm/waypoint1_z" value="$(arg point1_z)"/>
    <param name="fsm/waypoint2_x" value="$(arg point2_x)"/>
    <param name="fsm/waypoint2_y" value="$(arg point2_y)"/>
    <param name="fsm/waypoint2_z" value="$(arg point2_z)"/>
    <param name="fsm/waypoint3_x" value="$(arg point3_x)"/>
    <param name="fsm/waypoint3_y" value="$(arg point3_y)"/>
    <param name="fsm/waypoint3_z" value="$(arg point3_z)"/>
    <param name="fsm/waypoint4_x" value="$(arg point4_x)"/>
    <param name="fsm/waypoint4_y" value="$(arg point4_y)"/>
    <param name="fsm/waypoint4_z" value="$(arg point4_z)"/>

    <!-- grid_map -->
    <param name="grid_map/resolution" value="0.2"/>
    <param name="grid_map/map_size_x" value="$(arg map_size_x_)"/>
    <param name="grid_map/map_size_y" value="$(arg map_size_y_)"/>
    <param name="grid_map/map_size_z" value="$(arg map_size_z_)"/>
    <param name="grid_map/local_update_range_x" value="5.5"/>
    <param name="grid_map/local_update_range_y" value="5.5"/>
    <param name="grid_map/local_update_range_z" value="4.5"/>
    <param name="grid_map/obstacles_inflation"  value="0.25"/>
    <param name="grid_map/local_map_margin"     value="10"/>
    <param name="grid_map/ground_height"        value="-0.15"/>

    <param name="grid_map/cx" value="$(arg cx)"/>
    <param name="grid_map/cy" value="$(arg cy)"/>
    <param name="grid_map/fx" value="$(arg fx)"/>
    <param name="grid_map/fy" value="$(arg fy)"/>

    <!-- 点云模式：关闭深度滤波 -->
    <param name="grid_map/use_depth_filter"       value="false"/>
    <param name="grid_map/depth_filter_tolerance" value="0.20"/>
    <param name="grid_map/depth_filter_maxdist"   value="6.0"/>
    <param name="grid_map/depth_filter_mindist"   value="0.3"/>
    <param name="grid_map/depth_filter_margin"    value="2"/>
    <param name="grid_map/k_depth_scaling_factor" value="1.0"/>
    <param name="grid_map/skip_pixel"             value="4"/>

    <param name="grid_map/p_hit"  value="0.60"/>
    <param name="grid_map/p_miss" value="0.40"/>
    <param name="grid_map/p_min"  value="0.12"/>
    <param name="grid_map/p_max"  value="0.90"/>
    <param name="grid_map/p_occ"  value="0.75"/>

    <param name="grid_map/min_ray_length" value="0.2"/>
    <param name="grid_map/max_ray_length" value="6.0"/>
    <param name="grid_map/virtual_ceil_height"          value="3.2"/>
    <param name="grid_map/visualization_truncate_height" value="2.2"/>
    <param name="grid_map/show_occ_time" value="false"/>
    <!-- 关键：统一在 world 坐标系 -->
    <param name="grid_map/pose_type" value="0"/>
    <param name="grid_map/frame_id"  value="world"/>

    <!-- manager / optimization / bspline / prediction -->
    <param name="manager/max_vel" value="$(arg max_vel)"/>
    <param name="manager/max_acc" value="$(arg max_acc)"/>
    <param name="manager/max_jerk" value="4.0"/>
    <param name="manager/control_points_distance" value="0.4"/>
    <param name="manager/feasibility_tolerance"   value="0.05"/>
    <param name="manager/planning_horizon"        value="$(arg planning_horizon)"/>
    <param name="manager/use_distinctive_trajs"   value="$(arg use_distinctive_trajs)"/>
    <param name="manager/drone_id"                value="$(arg drone_id)"/>

    <param name="optimization/lambda_smooth"     value="1.0"/>
    <param name="optimization/lambda_collision"  value="0.5"/>
    <param name="optimization/lambda_feasibility" value="0.1"/>
    <param name="optimization/lambda_fitness"    value="1.0"/>
    <param name="optimization/dist0"             value="0.5"/>
    <param name="optimization/swarm_clearance"   value="0.5"/>
    <param name="optimization/max_vel"           value="$(arg max_vel)"/>
    <param name="optimization/max_acc"           value="$(arg max_acc)"/>

    <param name="bspline/limit_vel"  value="$(arg max_vel)"/>
    <param name="bspline/limit_acc"  value="$(arg max_acc)"/>
    <param name="bspline/limit_ratio" value="1.1"/>

    <param name="prediction/obj_num"     value="$(arg obj_num_set)"/>
    <param name="prediction/lambda"      value="1.0"/>
    <param name="prediction/predict_rate" value="1.0"/>
  </node>
</launch>
